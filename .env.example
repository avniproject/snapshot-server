# --- avni-server ---
AVNI_SERVER_URL=https://staging.avniproject.org

# AUTH-TOKEN sent on every request. Required when avni-server runs with
# AVNI_IDP_TYPE=cognito (staging functional testing). Leave blank in
# production where the dedicated snapshot-server avni-server instance runs
# with AVNI_IDP_TYPE=none and identifies the user from USER-NAME.
AUTH_TOKEN=

# --- snapshot-server ---
LOG_LEVEL=info
STATE_DB_PATH=./snapshot-db/snapshot-server.db
SNAPSHOTS_DIR=./snapshots
PAGE_SIZE=1000
REPLICA_LAG_MINUTES=10
MAX_CONCURRENCY=1
HTTP_PORT=3000

# --- s3 (used later by S3Uploader) ---
S3_BUCKET=
S3_PREFIX=snapshot-v2/sqlite
AWS_REGION=ap-south-1
