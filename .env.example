# --- avni-server ---
AVNI_SERVER_URL=https://staging.avniproject.org

# AUTH-TOKEN sent on every request. Required when avni-server runs with
# AVNI_IDP_TYPE=cognito (staging functional testing). Leave blank in
# production where the dedicated snapshot-server avni-server instance runs
# with AVNI_IDP_TYPE=none and identifies the user from USER-NAME.
AUTH_TOKEN=

# --- snapshot-server ---
LOG_LEVEL=info
STATE_DB_PATH=./snapshot-db/snapshot-server.db
SNAPSHOTS_DIR=./snapshots
PAGE_SIZE=1000
REPLICA_LAG_MINUTES=10
MAX_CONCURRENCY=1
HTTP_PORT=3000
# Per-page fetch timeout in ms. Default 300000 (5 min); raise if you see
# `syncTimeoutError` from heavy ProgramEncounter/Encounter pages.
FETCH_TIMEOUT_MS=300000

# --- AWS / S3 ---
# Variable names match what avni-infra exports for avni-server, so the same
# ansible group_vars / shell exports apply to snapshot-server unchanged.
# Leave OPENCHS_BUCKET_NAME empty to disable uploads entirely (snapshots stay
# on local disk under SNAPSHOTS_DIR). Leave the IAM keys empty on EC2 to let
# the SDK pick up the instance role automatically.
OPENCHS_BUCKET_NAME=
OPENCHS_AWS_REGION=ap-south-1
OPENCHS_IAM_USER_ACCESS_KEY=
OPENCHS_IAM_USER_SECRET_ACCESS_KEY=
